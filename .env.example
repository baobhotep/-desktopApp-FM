# Port serwera HTTP (domyślnie 8080)
PORT=8080

# Sekret JWT – w produkcji ustaw na silną, losową wartość
JWT_SECRET=change-me-in-production

# Baza danych (domyślnie H2 w pamięci)
# DATABASE_URL=jdbc:h2:mem:fmgame;DB_CLOSE_DELAY=-1
# Dla PostgreSQL np.:
# DATABASE_URL=jdbc:postgresql://localhost:5432/fmgame?user=postgres&password=...

# Katalog z zbudowanym frontendem (statyczne pliki)
FRONTEND_DIR=frontend

# Produkcja – wymusza ustawienie JWT_SECRET
# ENV=production

# Opcjonalnie: sekret do endpointów admin (upload modeli xG/VAEP)
# ADMIN_SECRET=...

# Opcjonalnie: konfiguracja silnika (formuła vs modele ONNX)
# ENGINE_XG_MODEL=formula
# ENGINE_VAEP_MODEL=formula
# ENGINE_XG_PATH=/path/to/model.onnx
# ENGINE_VAEP_PATH=/path/to/vaep.onnx
